<mujoco model="double_pendulum">

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <worldbody>

        <!-- Link 1 -->
        <body name="link1" pos="0 0 0">

            <joint name="joint1"
                   type="hinge"
                   axis="0 1 0"
                   damping="0"/>

            <geom type="capsule"
                  fromto="0 0 0 0 0 -1"
                  size="0.05"
                  density="1000"/>

            <!-- Link 2 -->
            <body name="link2" pos="0 0 -1">

                <joint name="joint2"
                       type="hinge"
                       axis="0 1 0"
                       damping="0"/>

                <geom type="capsule"
                      fromto="0 0 0 0 0 -1"
                      size="0.05"
                      density="1000"/>

            </body>

        </body>

    </worldbody>

    <!-- ONLY SECOND JOINT ACTUATED -->
    <actuator>
        <motor joint="joint1"
               ctrlrange="-20 20"
               gear="1"/>
    </actuator>

</mujoco>