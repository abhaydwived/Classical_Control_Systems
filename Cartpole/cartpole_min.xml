<mujoco model="cartpole_balance">

    <option timestep="0.005"
            gravity="0 0 -9.81"
            integrator="RK4"/>

    <visual>
        <global fovy="45" linewidth="2"/>
        <quality shadowsize="2048"/>
        <map stiffness="700" shadowscale="0.5"/>
    </visual>

    <worldbody>

        <!-- Ground -->
        <!-- <geom type="plane"
              size="5 5 0.1"
              rgba="0.75 0.75 0.75 1"/> -->

        <!-- Rail / Track indicator -->
        <!-- <geom type="capsule"
              fromto="-2.5 0 0.1  2.5 0 0.1"
              size="0.02"
              rgba="0.4 0.4 0.4 1"/> -->

        <!-- Cart body (slides along X) -->
        <body name="cart" pos="0 0 0.1">

            <!-- Slide joint – cart can move ±2 m along X -->
            <joint name="cart_slide"
                   type="slide"
                   axis="1 0 0"
                   limited="true"
                   range="-2 2"
                   damping="0"/>

            <!-- Cart geometry -->
            <geom type="box"
                  size="0.15 0.08 0.06"
                  rgba="0.2 0.4 0.9 1"
                  mass="1.0"/>

            <!-- Wheel decorations (visual only) -->
            <!-- <geom type="cylinder" pos=" 0.12 0.09 -0.05" size="0.04 0.01" rgba="0.1 0.1 0.1 1"/>
            <geom type="cylinder" pos="-0.12 0.09 -0.05" size="0.04 0.01" rgba="0.1 0.1 0.1 1"/>
            <geom type="cylinder" pos=" 0.12 -0.09 -0.05" size="0.04 0.01" rgba="0.1 0.1 0.1 1"/>
            <geom type="cylinder" pos="-0.12 -0.09 -0.05" size="0.04 0.01" rgba="0.1 0.1 0.1 1"/> -->

            <!-- Pole mounted on top of cart -->
            <body name="pole" pos="0 0 0.06">

                <!-- Hinge joint (rotates in XZ plane, axis Y) -->
                <joint name="pole_hinge"
                       type="hinge"
                       axis="0 1 0"
                       range="-1.5708 1.5708"
                       damping="0"/>

                <!-- Pole geometry – extends upward -->
                <geom type="capsule"
                      fromto="0 0 0  0 0 0.6"
                      size="0.025"
                      rgba="0.9 0.2 0.2 1"
                      mass="0.25"/>

                <!-- Bob at tip for visual clarity -->
                <geom type="sphere"
                      pos="0 0 0.6"
                      size="0.035"
                      rgba="1.0 0.6 0.0 1"
                      mass="0"/>

            </body>

        </body>

    </worldbody>

    <actuator>
        <!-- Force on cart slide only (no direct torque on pole) -->
        <motor joint="cart_slide"
               ctrlrange="-25 25"
               gear="1"
               name="cart_force"/>
    </actuator>

    <!-- Default camera for a clean side view -->
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    </visual>

    <keyframe>
    <key
        time="0"
        qpos="0 -0.251328"
        qvel="0 0"
        ctrl="0"
    />
    </keyframe>  

</mujoco>