<mujoco model="wheel_on_stick">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>


    <worldbody>

        <!-- Visual pedestal under the hinge -->
        <geom name="pedestal" type="cylinder"
              pos="0 0 0.14"
              size="0.12 0.2"
              contype="0" conaffinity="0"
              rgba="0.18 0.20 0.22 0.6"/>

        <camera name="side"
                pos="0 -4 1.7"
                quat="0.9239 0.3827 0 0"/>

        <body name="stick" pos="0 0 0.3">
            <joint name="stick_hinge"
                   type="hinge"
                   axis="0 1 0"/>

            <geom name="stick_geom" type="capsule"
                  fromto="0 0 0  0 0 0.7"
                  mass="0.6"
                  size="0.05"
                  rgba="0.14 0.16 0.19 0.6"
                  contype="0"
                  conaffinity="0"/>

            <!-- Small physical mass near the base to avoid an unrealistically top-heavy link -->
            <geom name="base_counterweight" type="sphere"
                  pos="0 0 0.06"
                  size="0.06"
                  mass="0.45"
                  rgba="0.10 0.10 0.11 0.6"
                  contype="0"
                  conaffinity="0"/>

            <body name="wheel" pos="0 0 0.7">
                <joint name="wheel_spin"
                       type="hinge"
                       axis="0 1 0"/>

                <geom name="wheel_rim" type="cylinder"
                      size="0.15 0.02"
                      mass="0.5"
                      quat="0.7071 0.7071 0 0"
                      rgba="0.82 0.84 0.87 1.0"
                      contype="0"
                      conaffinity="0"/>

                <geom name="wheel_hub" type="sphere"
                      size="0.07"
                      mass="0.25"
                      rgba="0.10 0.10 0.11 1.0"
                      contype="0"
                      conaffinity="0"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="wheel_motor"
               joint="wheel_spin"
               ctrlrange="-50 50"/>
    </actuator>
</mujoco>